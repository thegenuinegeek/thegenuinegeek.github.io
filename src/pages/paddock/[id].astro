---
import Base from '../../layouts/Base.astro';
import CRTFrame from '../../components/CRTFrame.astro';
import ArticleHero from '../../components/ArticleHero.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('paddock');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const readTime = getReadingTime(post.body || '');
const articleUrl = new URL(`/paddock/${post.id}`, Astro.site).href;
---

<Base title={post.data.title} description={post.data.description} activePylon="/paddock" image={post.data.image}>
  <article class="px-8 md:px-12 py-14 max-w-4xl mx-auto">
    <a href="/paddock" class="font-mono text-[10px] text-steel hover:text-amber-400 transition-colors tracking-wider">&larr; BACK TO THE PADDOCK</a>
    <div class="mt-6 mb-2 flex items-center flex-wrap gap-3 font-mono text-[10px] tracking-widest">
      <span class="border border-amber-400 text-amber-400 px-1.5 py-0.5 font-bold">PADDOCK</span>
      <span class="text-steel/50">{dateStr}</span>
      <span class="text-steel/30">&middot;</span>
      <span class="text-steel/40">{readTime}</span>
      <span class="flex-1"></span>
      <ShareButtons title={post.data.title} url={articleUrl} />
    </div>
    <h1 class="font-mono text-2xl font-bold text-chrome mb-6">{post.data.title}</h1>

    <ArticleHero title={post.data.title} image={post.data.image} section="paddock" />

    <div class="border border-gunmetal bg-gunmetal/20 p-3 mb-6 font-mono text-xs">
      <span class="text-steel/50">GUEST:</span>
      <span class="text-chrome ml-2">{post.data.guest}</span>
      {post.data.guestTitle && <span class="text-steel/40 ml-2">- {post.data.guestTitle}</span>}
    </div>

    {post.data.youtubeId && (
      <div class="mb-8">
        <CRTFrame youtubeId={post.data.youtubeId} title={post.data.title} />
      </div>
    )}

    <div class="article-body article-body--paddock max-w-none font-sans text-steel text-sm leading-relaxed">
      <Content />
    </div>

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex gap-2 mt-8 flex-wrap border-t border-gunmetal pt-4">
        {post.data.tags.map(tag => (
          <a href={`/tags/${tag}`} class="font-mono text-[9px] text-terminal/50 hover:text-terminal tracking-wider transition-colors">#{tag}</a>
        ))}
      </div>
    )}

  </article>
</Base>
