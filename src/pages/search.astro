---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const sprint = (await getCollection('sprint')).map(e => ({
  title: e.data.title,
  description: e.data.description,
  tags: e.data.tags || [],
  section: 'sprint' as const,
  href: `/sprint/${e.id}`,
  pubDate: e.data.pubDate.toISOString(),
}));

const workbench = (await getCollection('workbench')).map(e => ({
  title: e.data.title,
  description: e.data.description,
  tags: e.data.tags || [],
  section: 'workbench' as const,
  href: `/workbench/${e.id}`,
  pubDate: e.data.pubDate.toISOString(),
}));

const paddock = (await getCollection('paddock')).map(e => ({
  title: e.data.title,
  description: e.data.description,
  tags: e.data.tags || [],
  section: 'paddock' as const,
  href: `/paddock/${e.id}`,
  pubDate: e.data.pubDate.toISOString(),
}));

const allArticles = [...sprint, ...workbench, ...paddock].sort(
  (a, b) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf()
);
---

<Base title="Search" description="Search all Genuine Geek Media articles." activePylon="/search">
  <section class="px-8 md:px-12 py-14 font-mono">
    <div class="terminal-header mb-8 text-[10px] text-steel/40 tracking-widest uppercase">
      Genuine Geek Systems v2.0 // Index Search Terminal
    </div>

    <div id="terminal-history" class="space-y-4 mb-6">
      <div class="text-steel/60 text-sm tracking-wider">
        READY FOR INPUT. TYPE 'HELP' FOR COMMANDS.
      </div>
    </div>

    <div class="flex items-center gap-2 text-terminal">
      <span class="font-bold select-none">$</span>
      <input
        id="search-input"
        type="text"
        class="flex-1 bg-transparent border-none p-0 font-mono text-sm text-chrome placeholder:text-steel/20 tracking-wider focus:outline-none focus:ring-0"
        autocomplete="off"
        spellcheck="false"
        autofocus
      />
    </div>

    <script id="search-data" type="application/json" set:html={JSON.stringify(allArticles)}></script>
    <div id="search-results-container" class="mt-8 hidden">
      <div id="search-results" class="space-y-3"></div>
    </div>
  </section>
</Base>

<script>
  import Fuse from 'fuse.js';

  const sectionColorClasses: Record<string, { text: string; border: string }> = {
    sprint: { text: 'text-octane', border: 'border-octane' },
    workbench: { text: 'text-terminal', border: 'border-terminal' },
    paddock: { text: 'text-amber-400', border: 'border-amber-400' },
  };

  const sectionLabels: Record<string, string> = {
    sprint: 'SPRINT',
    workbench: 'WORKBENCH',
    paddock: 'PADDOCK',
  };

  const dataEl = document.getElementById('search-data');
  const allArticles = JSON.parse(dataEl?.textContent || '[]');

  const fuse = new Fuse(allArticles, {
    keys: [
      { name: 'title', weight: 0.4 },
      { name: 'description', weight: 0.3 },
      { name: 'tags', weight: 0.3 },
    ],
    threshold: 0.4,
    includeScore: true,
  });

  const input = document.getElementById('search-input') as HTMLInputElement;
  const historyEl = document.getElementById('terminal-history')!;
  const resultsContainer = document.getElementById('search-results-container')!;
  const resultsEl = document.getElementById('search-results')!;

  function addHistory(text: string, colorClass = 'text-steel/60') {
    const line = document.createElement('div');
    line.className = `text-sm tracking-wider ${colorClass}`;
    line.innerHTML = text;
    historyEl.appendChild(line);
    window.scrollTo(0, document.body.scrollHeight);
  }

  async function performSearch(query: string) {
    addHistory(`$ ${query}`, 'text-chrome');
    
    const command = query.trim().toLowerCase();
    
    if (command === 'help') {
      addHistory('AVAILABLE COMMANDS:', 'text-octane');
      addHistory('> HELP : SHOW THIS LIST');
      addHistory('> CLEAR : WIPE TERMINAL HISTORY');
      addHistory('> [QUERY] : SEARCH THE DATABASE');
      input.value = '';
      return;
    }

    if (command === 'clear') {
      historyEl.innerHTML = '';
      resultsEl.innerHTML = '';
      resultsContainer.classList.add('hidden');
      input.value = '';
      return;
    }

    if (!command) return;

    addHistory(`SEARCHING DATABASE FOR: "${query.toUpperCase()}"...`, 'text-terminal/60');
    
    // Simulate system lag for flavor
    await new Promise(r => setTimeout(r, 600));

    const results = fuse.search(query);

    if (results.length === 0) {
      addHistory('ERROR: NO ENTRIES MATCHING QUERY FOUND.', 'text-red-500/80');
      resultsContainer.classList.add('hidden');
    } else {
      addHistory(`SUCCESS: ${results.length} ENTRIES RETRIEVED.`, 'text-terminal');
      resultsContainer.classList.remove('hidden');
      resultsEl.innerHTML = results.map(({ item: a }) => {
        const colors = sectionColorClasses[a.section];
        const label = sectionLabels[a.section];
        return `<a href="${a.href}" class="block border border-gunmetal bg-gunmetal/20 p-5 hover:bg-gunmetal/40 hover:border-octane/30 transition-all no-underline">
          <div class="flex items-center gap-3 mb-2 font-mono text-[10px] tracking-widest">
            <span class="border px-1.5 py-0.5 font-bold ${colors.text} ${colors.border}">${label}</span>
          </div>
          <div class="font-mono font-bold text-chrome text-sm leading-snug">${a.title}</div>
          <div class="text-steel/70 text-xs mt-2 leading-relaxed font-sans">${a.description}</div>
        </a>`;
      }).join('');
    }

    input.value = '';
    window.scrollTo(0, document.body.scrollHeight);
  }

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      performSearch(input.value);
    }
  });

  // Keep focus on input
  document.addEventListener('click', () => input.focus());
</script>
