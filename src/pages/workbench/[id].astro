---
import Base from '../../layouts/Base.astro';
import CRTFrame from '../../components/CRTFrame.astro';
import ArticleHero from '../../components/ArticleHero.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('workbench');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const allSprint = (await getCollection('sprint')).map(p => ({ id: p.id, data: p.data, section: 'sprint' as const }));
const allWorkbench = (await getCollection('workbench')).map(p => ({ id: p.id, data: p.data, section: 'workbench' as const }));
const allPaddock = (await getCollection('paddock')).map(p => ({ id: p.id, data: p.data, section: 'paddock' as const }));
const allPosts = [...allSprint, ...allWorkbench, ...allPaddock];

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const readTime = getReadingTime(post.body || '');
const articleUrl = new URL(`/workbench/${post.id}`, Astro.site).href;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  author: { '@type': 'Person', name: 'James Schoepf' },
  publisher: { '@type': 'Organization', name: 'Genuine Geek Media' },
  url: articleUrl,
  ...(post.data.image ? { image: new URL(post.data.image, Astro.site).href } : {}),
});
---

<Base title={post.data.title} description={post.data.description} activePylon="/workbench" image={post.data.image}>
  <script type="application/ld+json" set:html={jsonLd} />
  <article class="px-8 md:px-12 py-14 max-w-4xl mx-auto">
    <a href="/workbench" class="font-mono text-[10px] text-steel hover:text-terminal transition-colors tracking-wider">&larr; BACK TO THE WORKBENCH</a>
    <div class="mt-6 mb-2 flex items-center flex-wrap gap-3 font-mono text-[10px] tracking-widest">
      <span class="border border-terminal text-terminal px-1.5 py-0.5 font-bold">WORKBENCH</span>
      <span class="text-steel/80">{dateStr}</span>
      <span class="text-steel/50">&middot;</span>
      <span class="text-steel/70">{readTime}</span>
      {post.data.series && <span class="text-amber-400/60">SERIES: {post.data.series}</span>}
      <span class="flex-1"></span>
      <ShareButtons title={post.data.title} url={articleUrl} />
    </div>
    <h1 class="font-mono text-2xl font-bold text-chrome mb-6">{post.data.title}</h1>

    <ArticleHero title={post.data.title} image={post.data.image} section="workbench" />

    {post.data.youtubeId && (
      <div class="mb-6 font-mono text-[10px] tracking-wider">
        <a href="#video" class="text-terminal hover:text-terminal/80 transition-colors">&#9656; Skip the rambling, jump to the video</a>
      </div>
    )}

    <div class="article-body article-body--workbench max-w-none font-sans text-steel text-sm leading-relaxed">
      <Content />
    </div>

    {post.data.youtubeId && (
      <div id="video" class="mt-10 mb-6">
        <div class="font-mono text-[10px] text-steel/70 tracking-widest mb-3">&#9656; WATCH</div>
        <CRTFrame youtubeId={post.data.youtubeId} title={post.data.title} />
      </div>
    )}

    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex gap-2 mt-8 flex-wrap border-t border-gunmetal pt-4">
        {post.data.tags.map(tag => (
          <a href={`/tags/${tag}`} class="font-mono text-[9px] text-terminal/50 hover:text-terminal tracking-wider transition-colors">#{tag}</a>
        ))}
      </div>
    )}

    <RelatedArticles currentId={post.id} tags={post.data.tags || []} section="workbench" allPosts={allPosts} />

  </article>
</Base>
