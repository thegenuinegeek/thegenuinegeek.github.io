---
import Base from '../../layouts/Base.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('sprint')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title="The Sprint" activePylon="/sprint">
  <section class="px-6 py-12">
    <div class="mb-8">
      <h1 class="font-mono text-xl font-bold text-octane tracking-wider">THE SPRINT</h1>
      <p class="font-mono text-xs text-steel mt-1 tracking-wider">Quick-hit news from tech, motorsport, and geek culture.</p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map(entry => (
        <EpisodeCard
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
          href={`/sprint/${entry.id}`}
          tags={entry.data.tags}
          section="sprint"
        />
      ))}
    </div>
  </section>
</Base>
