---
import Base from '../layouts/Base.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import NowPlaying from '../components/NowPlaying.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/readingTime';

const allSprint = (await getCollection('sprint')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const allWorkbench = (await getCollection('workbench')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const allPaddock = (await getCollection('paddock')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
---

<Base title="Mission Control" description="Silicon & Steel. Tech, gaming, motorsport, and geek culture from James Schoepf." image="/images/GGMEDIA-Site-main-preview-Image.jpg">
  <!-- HERO -->
  <div class="px-4 md:px-8 pt-6 pb-2">
    <div class="crt-hero">
      <!-- CRT bezel frame -->
      <div class="crt-hero__bezel">
        <!-- Screen area -->
        <div class="crt-hero__screen">
          <!-- Static fuzz -->
          <div class="crt-hero__fuzz" aria-hidden="true"></div>
          <!-- Scanlines -->
          <div class="crt-hero__scanlines" aria-hidden="true"></div>
          <!-- Vignette -->
          <div class="crt-hero__vignette" aria-hidden="true"></div>
          <!-- Content -->
          <div class="crt-hero__content">
            <div class="font-mono text-terminal text-xs tracking-[0.3em] mb-4">// BOOT SEQUENCE INITIATED</div>

            <div id="typewriter" class="font-mono text-sm sm:text-xl md:text-3xl font-bold text-chrome leading-snug flex flex-col items-center justify-center">
              <div id="tw-line1" class="min-h-[2.6em] sm:min-h-[1.4em] flex items-center">&nbsp;</div>
              <div id="tw-line2" class="text-octane mt-2 min-h-[1.4em] flex items-center">&nbsp;</div>
            </div>

            <div class="mt-6 flex items-center justify-center gap-4 md:gap-8 font-mono text-[10px] md:text-xs text-steel">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-octane inline-block"></span>
                <span>HUSBAND</span>
              </div>
              <span class="text-gunmetal">|</span>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-terminal inline-block animate-pulse"></span>
                <span>DAD</span>
              </div>
              <span class="text-gunmetal">|</span>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-amber-400 inline-block"></span>
                <span>GAMER</span>
              </div>
              <span class="text-gunmetal">|</span>
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-terminal inline-block"></span>
                <span>IT PRO</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Monitor stand -->
      <div class="flex justify-center">
        <div class="h-3 w-24 md:w-32" style="background: linear-gradient(180deg, #2a2a2a, #1a1a1a); border-radius: 0 0 4px 4px;"></div>
      </div>
    </div>
  </div>

  <!-- NOW PLAYING -->
  <NowPlaying />

  <!-- LATEST FROM THE SPRINT -->
  <section class="px-8 md:px-12 py-14 border-b border-gunmetal">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-mono text-xs tracking-[0.2em] text-octane font-bold">&#9656; THE SPRINT &mdash; LATEST</h2>
      <a href="/sprint" class="font-mono text-[10px] text-steel hover:text-octane transition-colors tracking-wider">VIEW ALL &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {allSprint.map(entry => (
        <EpisodeCard
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
          href={`/sprint/${entry.id}`}
          tags={entry.data.tags}
          section="sprint"
          image={entry.data.image}
          readTime={getReadingTime(entry.body || '')}
        />
      ))}
    </div>
  </section>

  <!-- LATEST FROM THE WORKBENCH -->
  <section class="px-8 md:px-12 py-14 border-b border-gunmetal">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-mono text-xs tracking-[0.2em] text-terminal font-bold">&#9656; THE WORKBENCH &mdash; LATEST</h2>
      <a href="/workbench" class="font-mono text-[10px] text-steel hover:text-terminal transition-colors tracking-wider">VIEW ALL &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {allWorkbench.map(entry => (
        <EpisodeCard
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
          href={`/workbench/${entry.id}`}
          tags={entry.data.tags}
          section="workbench"
          image={entry.data.image}
          readTime={getReadingTime(entry.body || '')}
        />
      ))}
    </div>
  </section>

  <!-- LATEST FROM THE PADDOCK -->
  <section class="px-8 md:px-12 py-14">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-mono text-xs tracking-[0.2em] text-amber-400 font-bold">&#9656; THE PADDOCK &mdash; LATEST</h2>
      <a href="/paddock" class="font-mono text-[10px] text-steel hover:text-amber-400 transition-colors tracking-wider">VIEW ALL &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {allPaddock.map(entry => (
        <EpisodeCard
          title={entry.data.title}
          description={entry.data.description}
          pubDate={entry.data.pubDate}
          href={`/paddock/${entry.id}`}
          tags={entry.data.tags}
          section="paddock"
          image={entry.data.image}
          readTime={getReadingTime(entry.body || '')}
        />
      ))}
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gunmetal px-8 md:px-12 py-10 font-mono text-[10px] text-steel/40 tracking-wider flex items-center justify-between">
    <span>&copy; 2025 GENUINE GEEK MEDIA LLC</span>
    <span>SILICON &amp; STEEL</span>
  </footer>
</Base>

<script>
  function typewrite(el: HTMLElement, text: string, speed: number): Promise<void> {
    return new Promise((resolve) => {
      let i = 0;
      const interval = setInterval(() => {
        el.textContent = text.slice(0, i + 1) + '\u2588';
        i++;
        if (i >= text.length) {
          clearInterval(interval);
          el.textContent = text;
          resolve();
        }
      }, speed);
    });
  }

  async function boot() {
    const line1 = document.getElementById('tw-line1');
    const line2 = document.getElementById('tw-line2');
    if (!line1 || !line2) return;

    line1.textContent = '\u2588';
    line2.textContent = '';
    await new Promise(r => setTimeout(r, 400));
    await typewrite(line1, 'IDENTIFYING: GENUINE GEEK...', 45);
    await new Promise(r => setTimeout(r, 300));
    line2.textContent = '\u2588';
    await typewrite(line2, 'STATUS: AUTHENTIC.', 55);
  }

  boot();
</script>
