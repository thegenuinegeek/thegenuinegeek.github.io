---
import Base from '../layouts/Base.astro';
---

<Base title="404 - Signal Lost">
  <section class="flex items-center justify-center py-32 px-8">
    <div class="text-center max-w-md">
      <div class="font-mono text-terminal text-xs tracking-[0.3em] mb-4">// ERROR</div>
      <h1 class="font-mono text-5xl font-bold text-octane mb-4">404</h1>
      <p class="font-mono text-chrome text-sm tracking-wider mb-2">SIGNAL LOST</p>
      <p class="text-steel text-sm font-sans mb-8">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="font-mono text-xs text-octane border border-octane px-4 py-2 hover:bg-octane/10 transition-colors tracking-wider">RETURN TO MISSION CONTROL</a>
    </div>
  </section>
</Base>
