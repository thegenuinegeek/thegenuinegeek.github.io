---
import '../styles/global.css';
import HUDHeader from '../components/HUDHeader.astro';
import Pylon from '../components/Pylon.astro';
import MobileNav from '../components/MobileNav.astro';
import Scanlines from '../components/Scanlines.astro';

interface Props {
  title: string;
  description?: string;
  activePylon?: string;
}

const { title, description = 'Genuine Geek Media — Silicon & Steel', activePylon } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Genuine Geek Media" href="/rss.xml" />
  <title>{title} | Genuine Geek Media</title>
</head>
<body class="bg-[#050505] text-chrome font-sans antialiased">

  <!-- CRT MONITOR HOUSING -->
  <div class="crt-bezel">
    <!-- The "screen" area -->
    <div class="crt-screen">
      <Scanlines />
      <div class="crt-vignette" aria-hidden="true"></div>

      <!-- Screen layout: pylon left, content right -->
      <div class="crt-layout">
        <Pylon active={activePylon} />

        <div class="crt-main">
          <MobileNav active={activePylon} />
          <HUDHeader />
          <main class="min-h-screen">
            <slot />
          </main>
        </div>
      </div>
    </div>

    <!-- Monitor brand plate -->
    <div class="crt-brand">
      <span class="font-mono text-[10px] text-steel/30 tracking-[0.3em]">GENUINE GEEK MEDIA</span>
      <div class="flex items-center gap-3 mt-1">
        <span class="w-1.5 h-1.5 rounded-full bg-terminal/40"></span>
        <span class="font-mono text-[8px] text-steel/20 tracking-wider">PWR</span>
      </div>
    </div>
  </div>

</body>
</html>

<style is:global>
  .crt-bezel {
    min-height: 100vh;
    padding: 12px;
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .crt-bezel {
      padding: 20px 24px 16px;
    }
  }

  @media (min-width: 1280px) {
    .crt-bezel {
      padding: 28px 36px 20px;
    }
  }

  .crt-screen {
    flex: 1;
    position: relative;
    background: #0a0a0a;
    border: 1px solid #1f1f1f;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 0 40px rgba(255, 102, 0, 0.03),
      0 0 80px rgba(0, 255, 65, 0.02),
      inset 0 0 60px rgba(0, 0, 0, 0.5);
  }

  .crt-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 90;
    border-radius: 8px;
    background: radial-gradient(
      ellipse at center,
      transparent 50%,
      rgba(0, 0, 0, 0.3) 80%,
      rgba(0, 0, 0, 0.6) 100%
    );
  }

  .crt-layout {
    position: relative;
    z-index: 1;
    display: flex;
    flex: 1;
  }

  .crt-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .crt-brand {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 10px 0 2px;
  }
</style>
