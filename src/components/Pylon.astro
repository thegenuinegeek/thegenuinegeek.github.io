---
interface Props {
  active?: string;
}

const { active } = Astro.props;

const links = [
  { href: '/sprint', label: 'THE SPRINT', sub: 'News' },
  { href: '/workbench', label: 'THE WORKBENCH', sub: 'Deep Dives' },
  { href: '/paddock', label: 'THE PADDOCK', sub: 'Guests' },
  { href: '/about', label: 'ABOUT', sub: 'The Geek' },
  { href: '/search', label: 'SEARCH', sub: 'Find It' },
];
---

<!-- Desktop sidebar -->
<aside class="hidden lg:flex w-60 shrink-0 bg-matte-black border-r border-gunmetal flex-col font-mono text-xs select-none rounded-l-lg">
  <a href="/" class="block px-6 py-7 border-b border-gunmetal group">
    <div class="text-2xl font-bold tracking-[0.2em] text-octane">GGM</div>
    <div class="text-steel mt-2 tracking-wider text-xs">GENUINE GEEK MEDIA</div>
    <div class="h-px mt-3 w-12" style="background: linear-gradient(90deg, #cc99ff60, transparent);"></div>
  </a>

  <div class="flex-1 py-6">
    {links.map((link, i) => (
      <a
        href={link.href}
        class:list={[
          'group flex items-center gap-3 px-6 py-4 border-l-2 transition-colors',
          active === link.href
            ? 'border-octane bg-gunmetal/40 text-octane'
            : 'border-transparent text-steel hover:text-octane hover:border-octane/50 hover:bg-gunmetal/20',
        ]}
      >
        <span class="text-terminal font-bold w-4 text-right">{String(i + 1).padStart(2, '0')}</span>
        <div>
          <div class="font-bold tracking-wider text-[11px]">{link.label}</div>
          <div class="text-[10px] text-steel/60 tracking-wide mt-0.5">{link.sub}</div>
        </div>
      </a>
    ))}
  </div>

  <div class="px-6 py-6 border-t border-gunmetal text-[10px] tracking-wider">
    <div class="flex items-center gap-3 mb-3 font-mono text-steel/80">
      <a href="https://www.youtube.com/@thegenuinegeek" target="_blank" rel="noopener noreferrer" class="hover:text-octane transition-colors">YOUTUBE</a>
      <span class="text-gunmetal">|</span>
      <a href="https://x.com/thegenuinegeek" target="_blank" rel="noopener noreferrer" class="hover:text-octane transition-colors">X</a>
      <span class="text-gunmetal">|</span>
      <a href="https://tiktok.com/@thegenuinegeek" target="_blank" rel="noopener noreferrer" class="hover:text-octane transition-colors">TIKTOK</a>
      <span class="text-gunmetal">|</span>
      <a href="/rss.xml" class="hover:text-octane transition-colors">RSS</a>
    </div>
    <div class="text-steel/40">&copy; 2025 GGM LLC</div>
    <div class="mt-1 text-steel/40">SILICON &amp; STEEL</div>
  </div>
</aside>
