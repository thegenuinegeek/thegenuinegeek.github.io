---
interface Props {
  active?: string;
}

const { active } = Astro.props;

const links = [
  { href: '/sprint', label: 'THE SPRINT', sub: 'News' },
  { href: '/workbench', label: 'THE WORKBENCH', sub: 'Deep Dives' },
  { href: '/paddock', label: 'THE PADDOCK', sub: 'Guests' },
];
---

<nav id="pylon" class="fixed left-0 top-8 bottom-0 w-56 bg-matte-black border-r border-gunmetal z-40 flex flex-col font-mono text-xs select-none hidden lg:flex">
  <a href="/" class="block px-4 py-6 border-b border-gunmetal">
    <div class="text-octane font-bold text-sm tracking-widest">GGM</div>
    <div class="text-steel mt-1 tracking-wider">GENUINE GEEK MEDIA</div>
  </a>

  <div class="flex-1 py-4">
    {links.map((link, i) => (
      <a
        href={link.href}
        class:list={[
          'group flex items-center gap-3 px-4 py-3 border-l-2 transition-colors',
          active === link.href
            ? 'border-octane bg-gunmetal/40 text-octane'
            : 'border-transparent text-steel hover:text-octane hover:border-octane/50 hover:bg-gunmetal/20',
        ]}
      >
        <span class="text-terminal font-bold w-4 text-right">{String(i + 1).padStart(2, '0')}</span>
        <div>
          <div class="font-bold tracking-wider text-[11px]">{link.label}</div>
          <div class="text-[10px] text-steel/60 tracking-wide">{link.sub}</div>
        </div>
      </a>
    ))}
  </div>

  <div class="px-4 py-4 border-t border-gunmetal text-[10px] text-steel/40 tracking-wider">
    <div>© 2025 GGM LLC</div>
    <div class="mt-1">SILICON & STEEL</div>
  </div>
</nav>

<button
  id="pylon-toggle"
  class="lg:hidden fixed top-10 left-2 z-50 bg-gunmetal border border-gunmetal text-octane font-mono text-xs px-2 py-1"
  aria-label="Toggle navigation"
>
  ☰ NAV
</button>

<script>
  const toggle = document.getElementById('pylon-toggle');
  const pylon = document.getElementById('pylon');
  toggle?.addEventListener('click', () => {
    pylon?.classList.toggle('hidden');
    pylon?.classList.toggle('flex');
  });
</script>
