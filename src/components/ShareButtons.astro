---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
---

<div class="flex items-center gap-3 font-mono text-[10px] tracking-widest">
  <span class="text-steel/30">SHARE:</span>

  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="text-steel/50 hover:text-octane transition-colors"
    aria-label="Share on X"
  >X</a>

  <a
    href={`https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`}
    target="_blank"
    rel="noopener noreferrer"
    class="text-steel/50 hover:text-octane transition-colors"
    aria-label="Share on Reddit"
  >REDDIT</a>

  <button
    id="copy-link-btn"
    class="text-steel/50 hover:text-octane transition-colors cursor-pointer"
    aria-label="Copy link"
  >LINK</button>

  <span id="copy-confirm" class="text-terminal hidden">COPIED</span>
</div>

<script define:vars={{ url }}>
  const btn = document.getElementById('copy-link-btn');
  const confirm = document.getElementById('copy-confirm');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(url);
    confirm?.classList.remove('hidden');
    btn.classList.add('hidden');
    setTimeout(() => {
      confirm?.classList.add('hidden');
      btn?.classList.remove('hidden');
    }, 2000);
  });
</script>
