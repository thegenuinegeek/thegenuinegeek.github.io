---
const now = new Date();
const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
---

<header class="hidden lg:flex sticky top-0 z-50 h-10 bg-matte-black/90 backdrop-blur-sm border-b border-gunmetal items-center px-8 font-mono text-xs select-none">
  <div class="flex-1"></div>
  <div class="flex items-center gap-6">
    <div class="flex items-center gap-2">
      <span class="inline-block w-2 h-2 bg-terminal animate-pulse"></span>
      <span class="text-terminal tracking-widest">SYSTEM READY</span>
    </div>
    <span class="text-gunmetal">|</span>
    <span class="text-steel">{dateStr}</span>
    <span class="text-gunmetal">|</span>
    <span class="text-octane font-bold tracking-wider">GGM v1.0</span>
  </div>
</header>
