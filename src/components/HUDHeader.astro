---
const now = new Date();
const dateStr = now.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
---

<header class="fixed top-0 left-0 right-0 z-50 h-8 bg-matte-black border-b border-gunmetal flex items-center px-4 font-mono text-xs select-none">
  <div class="flex items-center gap-2">
    <span class="inline-block w-2 h-2 bg-terminal animate-pulse"></span>
    <span class="text-terminal tracking-widest">SYSTEM READY</span>
  </div>
  <div class="flex-1"></div>
  <div class="flex items-center gap-6 text-steel">
    <span>{dateStr}</span>
    <span class="text-octane font-bold tracking-wider">GGM v1.0</span>
  </div>
</header>
