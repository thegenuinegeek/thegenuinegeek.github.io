<button
  id="back-to-top"
  class="fixed bottom-6 right-6 z-50 bg-gunmetal border border-gunmetal text-octane font-mono text-[10px] tracking-wider px-3 py-2 opacity-0 pointer-events-none transition-opacity duration-300 hover:bg-gunmetal/80"
  aria-label="Back to top"
>
  &#9650; TOP
</button>

<script>
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 600) {
      btn?.classList.remove('opacity-0', 'pointer-events-none');
      btn?.classList.add('opacity-100');
    } else {
      btn?.classList.add('opacity-0', 'pointer-events-none');
      btn?.classList.remove('opacity-100');
    }
  });
  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
